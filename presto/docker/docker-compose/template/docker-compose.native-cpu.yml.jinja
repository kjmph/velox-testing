x-presto-native-worker-cpu: &cpu_worker_base
  extends:
    file: ../../docker-compose.common.yml
    service: presto-base-native-worker
  image: presto-native-worker-cpu:${PRESTO_IMAGE_TAG}
  ulimits: {nofile: {soft: 500000, hard: 500000}}
  # UCX same-host transports may use shared-memory IPC namespaces.
  ipc: host
  # Let UCX same-host transports that validate peer PIDs, e.g. CMA and POSIX
  # proc-fd sharing, see a common PID namespace during transport experiments.
  pid: host
  # SYS_NICE is required so that numactl --cpunodebind / --membind work inside
  # the container (needed for NUMA pinning of multi-worker CPU setups).
  cap_add:
    - SYS_NICE
    - SYS_PTRACE
  build:
    args:
      - GPU=OFF
  entrypoint: ["bash", "/opt/launch_presto_servers.sh"]
  command: []
  depends_on:
    - presto-coordinator
  volumes:
    # Mount /sys/devices/system/node so numactl inside the container can read
    # the host NUMA topology when deciding memory/cpu bindings.
    - /sys/devices/system/node:/sys/devices/system/node

services:
  presto-coordinator:
    extends:
      file: ../../docker-compose.common.yml
      service: presto-base-coordinator
    volumes:
      - ../../config/generated/cpu/etc_common:/opt/presto-server/etc
      - ../../config/generated/cpu/etc_coordinator/config_native.properties:/opt/presto-server/etc/config.properties
      - ../../config/generated/cpu/etc_coordinator/node.properties:/opt/presto-server/etc/node.properties
      - ../../config/generated/cpu/etc_coordinator/catalog/hive.properties:/opt/presto-server/etc/catalog/hive.properties

  {% if workers|length > 1 %}
  # Multi-worker CPU: one container per worker, each pinned to a NUMA node.
  # NUMA_NODE is read by launch_presto_servers.sh which wraps presto_server
  # with `numactl --cpunodebind=N --membind=N`.
  {% for worker in workers %}
  presto-native-worker-cpu-{{ worker.id }}:
    <<: *cpu_worker_base
    container_name: presto-native-worker-cpu-{{ worker.id }}
    environment:
      WORKER_ID: {{ worker.id }}
      NUMA_NODE: {{ worker.numa_node }}
      VELOX_UCX_CPU_EXCHANGE: "1"
      # Let UCX select the best available transport. Same-host CPU data
      # endpoints disable endpoint error handling below so UCX can choose SHM;
      # cross-host endpoints keep error handling and use the best safe transport
      # UCX can select from this set. Override to constrain experiments.
      UCX_TLS: "${UCX_TLS:-all}"
      UCX_LOG_LEVEL: "${UCX_LOG_LEVEL:-warn}"
      UCX_PROTO_INFO: "${UCX_PROTO_INFO:-n}"
      UCX_NET_DEVICES: "${UCX_NET_DEVICES:-all}"
      UCX_POSIX_USE_PROC_LINK: "${UCX_POSIX_USE_PROC_LINK:-y}"
      # Worker N's HTTP port is 100<N>0 (10000, 10010, 10020, ...) per
      # generate_presto_config.sh. The CPU UCX exchange derives the upstream
      # UCX listener as HTTP_port+3, matching the cuDF exchange port
      # convention.
      VELOX_UCX_CPU_PORT: "{{ 10000 + 10 * worker.id + 3 }}"
      VELOX_UCX_LOG_LEVEL: "${VELOX_UCX_LOG_LEVEL:-0}"
      VELOX_UCX_NUM_PROGRESS_THREADS: "${VELOX_UCX_NUM_PROGRESS_THREADS:-4}"
      # Optional override for the same-host transport fingerprint. If unset,
      # the worker hashes /proc/sys/kernel/random/boot_id plus IPC/PID
      # namespace identities.
      VELOX_UCX_CPU_HOST_ID: "${VELOX_UCX_CPU_HOST_ID:-}"
      # 1 enables UCX endpoint error handling for cross-host CPU data
      # endpoints. Same-host CPU worker-address endpoints disable it
      # automatically so UCX can select posix/sysv/cma.
      VELOX_UCX_CPU_ERROR_HANDLING: "${VELOX_UCX_CPU_ERROR_HANDLING:-1}"
      VELOX_UCX_CPU_PIPELINE_DEPTH: "${VELOX_UCX_CPU_PIPELINE_DEPTH:-1}"
      VELOX_UCX_CPU_RECV_QUEUE_HIGH_WATER: "${VELOX_UCX_CPU_RECV_QUEUE_HIGH_WATER:-256}"
      VELOX_UCX_CPU_RECV_QUEUE_LOW_WATER: "${VELOX_UCX_CPU_RECV_QUEUE_LOW_WATER:-128}"
      VELOX_UCX_CPU_MAX_PAGE_BYTES: "${VELOX_UCX_CPU_MAX_PAGE_BYTES:-16777216}"
      VELOX_UCX_CPU_TARGET_ROWS: "${VELOX_UCX_CPU_TARGET_ROWS:-512000}"
      SERVER_START_TIMESTAMP: ${SERVER_START_TIMESTAMP:-}
    volumes:
      - ../../config/generated/cpu/etc_common:/opt/presto-server/etc
      - ../../config/generated/cpu/etc_worker_{{ worker.id }}/node.properties:/opt/presto-server/etc/node.properties
      - ../../config/generated/cpu/etc_worker_{{ worker.id }}/config_native.properties:/opt/presto-server/etc/config.properties
      - ../../config/generated/cpu/etc_worker_{{ worker.id }}/catalog/hive.properties:/opt/presto-server/etc/catalog/hive.properties
  {% endfor %}
  {% else %}
  # Single-worker CPU: one container spanning all NUMA nodes via --interleave=all.
  presto-native-worker-cpu:
    <<: *cpu_worker_base
    container_name: presto-native-worker-cpu
    environment:
      VELOX_UCX_CPU_EXCHANGE: "1"
      # Let UCX select the best available transport. Same-host CPU data
      # endpoints disable endpoint error handling below so UCX can choose SHM;
      # cross-host endpoints keep error handling and use the best safe transport
      # UCX can select from this set. Override to constrain experiments.
      UCX_TLS: "${UCX_TLS:-all}"
      UCX_LOG_LEVEL: "${UCX_LOG_LEVEL:-warn}"
      UCX_PROTO_INFO: "${UCX_PROTO_INFO:-n}"
      UCX_NET_DEVICES: "${UCX_NET_DEVICES:-all}"
      UCX_POSIX_USE_PROC_LINK: "${UCX_POSIX_USE_PROC_LINK:-y}"
      # Single-worker container uses HTTP port 10000 (per generated config),
      # so UCX port = 10000 + 3.
      VELOX_UCX_CPU_PORT: "10003"
      VELOX_UCX_LOG_LEVEL: "${VELOX_UCX_LOG_LEVEL:-0}"
      VELOX_UCX_NUM_PROGRESS_THREADS: "${VELOX_UCX_NUM_PROGRESS_THREADS:-4}"
      # Optional override for the same-host transport fingerprint. If unset,
      # the worker hashes /proc/sys/kernel/random/boot_id plus IPC/PID
      # namespace identities.
      VELOX_UCX_CPU_HOST_ID: "${VELOX_UCX_CPU_HOST_ID:-}"
      # 1 enables UCX endpoint error handling for cross-host CPU data
      # endpoints. Same-host CPU worker-address endpoints disable it
      # automatically so UCX can select posix/sysv/cma.
      VELOX_UCX_CPU_ERROR_HANDLING: "${VELOX_UCX_CPU_ERROR_HANDLING:-1}"
      VELOX_UCX_CPU_PIPELINE_DEPTH: "${VELOX_UCX_CPU_PIPELINE_DEPTH:-1}"
      VELOX_UCX_CPU_RECV_QUEUE_HIGH_WATER: "${VELOX_UCX_CPU_RECV_QUEUE_HIGH_WATER:-256}"
      VELOX_UCX_CPU_RECV_QUEUE_LOW_WATER: "${VELOX_UCX_CPU_RECV_QUEUE_LOW_WATER:-128}"
      VELOX_UCX_CPU_MAX_PAGE_BYTES: "${VELOX_UCX_CPU_MAX_PAGE_BYTES:-16777216}"
      VELOX_UCX_CPU_TARGET_ROWS: "${VELOX_UCX_CPU_TARGET_ROWS:-512000}"
      SERVER_START_TIMESTAMP: ${SERVER_START_TIMESTAMP:-}
    volumes:
      - ../../config/generated/cpu/etc_common:/opt/presto-server/etc
      - ../../config/generated/cpu/etc_worker/node.properties:/opt/presto-server/etc/node.properties
      - ../../config/generated/cpu/etc_worker/config_native.properties:/opt/presto-server/etc/config.properties
      - ../../config/generated/cpu/etc_worker/catalog/hive.properties:/opt/presto-server/etc/catalog/hive.properties
  {% endif %}
